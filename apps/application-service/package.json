{
  "name": "@talentsync/application-service",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outdir=dist --packages=external",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@talentsync/config": "workspace:*",
    "@talentsync/models": "workspace:*",
    "@talentsync/types": "workspace:*",
    "@talentsync/auth-middlewares": "workspace:*",
    "@talentsync/validation-middleware": "workspace:*",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/swagger-ui-express": "^4.1.8"
  }
}