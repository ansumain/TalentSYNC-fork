FROM node:20-alpine AS pruner

ARG TURBO_VERSION=2.8.13

WORKDIR /app

RUN npm install -g pnpm

COPY . .

RUN pnpm dlx turbo@${TURBO_VERSION} prune @talentsync/web-app --docker


FROM node:20-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm

COPY --from=pruner /app/out/json/ .

RUN pnpm install --frozen-lockfile

COPY --from=pruner /app/out/full/ .

# Ensure tsconfig extends chain is resolvable in pruned workspace during Docker build.
COPY tsconfig.base.json ./tsconfig.base.json

RUN pnpm --filter @talentsync/web-app build


FROM nginx:alpine AS runtime

COPY --from=builder /app/apps/web-app/dist /usr/share/nginx/html

RUN printf '%s\n' \
  'server {' \
  '    listen 5173;' \
  '    server_name _;' \
  '    root /usr/share/nginx/html;' \
  '    index index.html;' \
  '' \
  '    location / {' \
  '        try_files $uri $uri/ /index.html;' \
  '    }' \
  '}' > /etc/nginx/conf.d/default.conf

EXPOSE 5173

CMD ["nginx", "-g", "daemon off;"]
