{
  "name": "@talentsync/resume-parser-service",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "worker:dev": "tsx --watch src/worker/resumeParser.worker.ts",
    "build": "esbuild src/server.ts --bundle=false --platform=node --format=esm --outdir=dist",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@talentsync/types": "workspace:*",
    "@talentsync/config": "workspace:*",
    "@talentsync/models": "workspace:*",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "node-tesseract-ocr": "^2.2.1",
    "pdf-parse": "1.1.1",
    "pdf-poppler": "^0.2.3"
  },
  "devDependencies": {
    "@types/multer": "^2.0.0",
    "@types/pdf-parse": "^1.1.5"
  }
}